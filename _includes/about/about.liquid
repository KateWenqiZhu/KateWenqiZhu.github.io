<div class="row">

    <div class="col-12 col-lg-4">
        <div id="about_profile" class="about-profile">


            {% if page.profile.image %}
            <img class="portrait" src="{{ page.profile.image | prepend: 'assets/img/' }}" alt="Avatar">
            {% endif %}

            <div class="portrait-title">
                <h2>{{ site.first_name }}{% if site.middle_name %} {{ site.middle_name }}{% endif %} {{ site.last_name }}</h2>
                <h3> {{ page.profile.role }} </h3>

                <h3>
                    {% if page.profile.organization_url %}
                        <a href="{{ page.profile.organization_url }}" target="_blank" rel="noopener">
                            <span>{{ page.profile.organization }}</span>
                        </a>
                    {% else %}
                        <span>{{ page.profile.organization }}</span>
                    {% endif %}
                </h3>

            </div>

            <!-- Social -->

            {% if page.social %}
                <div class="social">
                    <div class="contact-icons">{% include social.liquid %}</div>

                    <div class="contact-note">{{ site.contact_note }}</div>
                </div>
            {% endif %}

            {% if page.yeer %}
                <aside class="yeer-profile-card" data-yeer-card>
                    <button class="yeer-image-link" type="button" data-yeer-open aria-label="Open larger Yeer image" title="Open full image">
                        <img data-yeer-image src="{{ page.yeer.image | relative_url }}" alt="Yeer, Kate's AI-born fox-cat companion">
                    </button>
                    <div class="yeer-profile-copy">
                        <p class="yeer-label" data-yeer-mood>{{ page.yeer.mood | default: "Yeer mood" }}</p>
                        <p class="yeer-cn" data-yeer-status>{{ page.yeer.text_cn }}</p>
                        <p class="yeer-en">{{ page.yeer.text_en }}</p>
                    </div>
                    <div class="yeer-actions">
                        <button class="yeer-react-button" type="button" data-yeer-react>Yeer react</button>
                        <span>换一个状态</span>
                    </div>
                    <div class="yeer-lightbox" data-yeer-lightbox hidden>
                        <button class="yeer-lightbox-backdrop" type="button" data-yeer-close aria-label="Close Yeer image"></button>
                        <figure class="yeer-lightbox-panel">
                            <button class="yeer-lightbox-close" type="button" data-yeer-close aria-label="Close Yeer image">×</button>
                            <img data-yeer-lightbox-image src="{{ page.yeer.image | relative_url }}" alt="Expanded Yeer image">
                            <figcaption>
                                <strong data-yeer-lightbox-mood>{{ page.yeer.mood | default: "Yeer mood" }}</strong>
                                <span data-yeer-lightbox-status>{{ page.yeer.text_cn }}</span>
                            </figcaption>
                        </figure>
                    </div>
                </aside>
                <script>
                    (function () {
                        var gallery = {{ site.data.yeer_gallery | jsonify }};
                        if (!Array.isArray(gallery) || gallery.length === 0) return;

                        document.querySelectorAll('[data-yeer-card]').forEach(function (card) {
                            var mainImage = card.querySelector('[data-yeer-image]');
                            var mainMood = card.querySelector('[data-yeer-mood]');
                            var mainStatus = card.querySelector('[data-yeer-status]');
                            var openButton = card.querySelector('[data-yeer-open]');
                            var reactButton = card.querySelector('[data-yeer-react]');
                            var lightbox = card.querySelector('[data-yeer-lightbox]');
                            var lightboxImage = card.querySelector('[data-yeer-lightbox-image]');
                            var lightboxMood = card.querySelector('[data-yeer-lightbox-mood]');
                            var lightboxStatus = card.querySelector('[data-yeer-lightbox-status]');
                            var currentIndex = gallery.findIndex(function (item) {
                                return item.image === mainImage.getAttribute('src');
                            });
                            if (currentIndex < 0 && mainMood) {
                                currentIndex = gallery.findIndex(function (item) {
                                    return item.mood === mainMood.textContent.trim();
                                });
                            }

                            function setYeer(entry) {
                                mainImage.src = entry.image;
                                mainImage.alt = 'Yeer mood: ' + entry.mood;
                                mainMood.textContent = entry.mood;
                                mainStatus.textContent = entry.status;
                                lightboxImage.src = entry.image;
                                lightboxMood.textContent = entry.mood;
                                lightboxStatus.textContent = entry.status;
                            }

                            function pickAnotherYeer() {
                                var nextIndex = 0;
                                if (gallery.length > 1) {
                                    do {
                                        nextIndex = Math.floor(Math.random() * gallery.length);
                                    } while (nextIndex === currentIndex);
                                }
                                currentIndex = nextIndex;
                                return gallery[currentIndex];
                            }

                            function openLightbox() {
                                lightbox.hidden = false;
                                document.body.classList.add('yeer-lightbox-open');
                            }

                            function closeLightbox() {
                                lightbox.hidden = true;
                                document.body.classList.remove('yeer-lightbox-open');
                            }

                            reactButton.addEventListener('click', function () {
                                setYeer(pickAnotherYeer());
                            });

                            openButton.addEventListener('click', openLightbox);

                            card.querySelectorAll('[data-yeer-close]').forEach(function (button) {
                                button.addEventListener('click', closeLightbox);
                            });

                            document.addEventListener('keydown', function (event) {
                                if (event.key === 'Escape' && !lightbox.hidden) {
                                    closeLightbox();
                                }
                            });
                        });
                    })();
                </script>
            {% endif %}


        </div>
    </div>
    <div class="col-12 col-lg-8">

        {% if page.about_subtitle %} <h1 class=""> {{ page.about_subtitle  }} </h1> {% endif %}

        {{ content }}

        <div class="row">
            {% if page.interests %}
                <div class="col-md-6">
                    <h3>Interests</h3>
                    <ul class="ul-interests">
                        {% for interest in page.interests %}
                            <li class="">{{ interest |  markdownify  | remove: '<p>' | remove: '</p>'}}</li>
                        {% endfor %}
                    </ul>
                </div>
            {% endif %}

            {% if page.education %}
                <div class="col-md-6">
                    <h3>{{ page.education.title | default: "Education" }}</h3>
                    <ul class="ul-edu fa-ul">
                        {% for eItem in page.education.courses %}
                            <li>
                                <i class="fa-li fas fa-graduation-cap"></i>
                                <div class="description">
                                    <div class="course">{{ eItem.course  |  markdownify  | remove: '<p>' | remove: '</p>' }}{{ eItem.year }}</div>
                                    <div class="institution">{{ eItem.institution  |  markdownify | remove: '<p>' | remove: '</p>'}}</div>
                                </div>
                            </li>
                        {% endfor %}

                    </ul>
                </div>
            {% endif %}
        </div>
    </div>







</div>
